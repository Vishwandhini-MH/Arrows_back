PORT=5000
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call this backend.
# Example for Vite: http://localhost:5173
# Example for Create React App: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173

# Your Superset Docker URL.
SUPERSET_BASE_URL=http://localhost:8088

# Superset service account credentials.
# In production, use a dedicated service account with only the permissions it needs.
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin
SUPERSET_PROVIDER=db

# Dashboard UUID from Superset Dashboard -> Embed dashboard.
SUPERSET_DASHBOARD_UUID=replace-with-your-dashboard-uuid

# Optional guest identity shown to Superset. You can later replace these
# with values from your own authenticated application user.
SUPERSET_GUEST_USERNAME=embedded_user
SUPERSET_GUEST_FIRST_NAME=Embedded
SUPERSET_GUEST_LAST_NAME=User
